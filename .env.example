# Copy to .env and fill in as needed

# Path for SQLite database (used by backend)
DATABASE_PATH=/data/psamate.db

# Backend port
PORT=3000

# OAuth redirect URI (set to your public URL if running behind a reverse proxy)
OAUTH_REDIRECT_URI=http://localhost:3000/api/setup/callback

# Log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Parked polling interval in ms (default: 300000 = 5 min)
POLL_INTERVAL_PARKED=300000
